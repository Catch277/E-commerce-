@model IEnumerable<ECommerceWeb.Models.Product>

<div class="container py-5">

<h2 class="fw-bold mb-1">

    Danh mục:
    @ViewBag.CategoryName

</h2>

<p class="text-muted">

    Có @Model.Count() sản phẩm

</p>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <partial name="_ProductCard" model="item" />
        }

    </div>

</div>