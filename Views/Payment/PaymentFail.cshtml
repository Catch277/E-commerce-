@{
    ViewData["Title"] = "Thanh toán thất bại";

    int? orderId = ViewBag.OrderId as int?;
    string? paymentMethod = ViewBag.PaymentMethod as string;
}

<div class="container py-5 d-flex justify-content-center">
    <div class="card border-0 shadow mx-auto text-center" style="max-width: 650px; border-radius: 12px; padding: 3rem 2rem;">
        <div class="mb-3">
            <i class="fa-solid fa-circle-xmark" style="font-size: 6rem; color: #dc3545;"></i>
        </div>
        
        <h2 class="fw-bold mb-3" style="color: #dc3545;">Giao dịch thất bại!</h2>
        
        <p class="fs-5 text-dark mb-4">
            Quá trình thanh toán không thành công hoặc đã bị hủy.<br/>
            Sản phẩm vẫn được giữ trong giỏ hàng của bạn.
        </p>

        @if (orderId.HasValue)
        {
            <p class="mb-3 text-dark">
                Mã đơn hàng: <strong>#@orderId</strong>
                @if (!string.IsNullOrWhiteSpace(paymentMethod))
                {
                    <span> &middot; Thanh toán qua @paymentMethod</span>
                }
            </p>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert mb-4 mx-auto" style="background-color: #f8d7da; color: #842029; border: none; max-width: 500px; border-radius: 8px;">
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="d-flex flex-wrap justify-content-center gap-3 mt-2">
            @if (orderId.HasValue)
            {
                <a asp-controller="Payment" asp-action="RetryPayment" asp-route-orderId="@orderId" class="btn fw-semibold" style="background-color: #f6b645; color: #000; padding: 10px 20px;">
                    <i class="fa-solid fa-rotate-left me-2"></i>Thanh toán lại
                </a>
            }
            <a asp-controller="Checkout" asp-action="Index" class="btn bg-white border-dark fw-semibold" style="color: #000; padding: 10px 20px;">
                <i class="fa-solid fa-arrow-left me-2"></i>Quay lại Checkout
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn fw-semibold" style="background-color: #6c757d; color: #fff; padding: 10px 20px;">
                <i class="fa-solid fa-house me-2"></i>Về trang chủ
            </a>
        </div>
    </div>
</div>
