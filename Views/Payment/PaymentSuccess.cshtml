@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container mt-5 text-center">
    <div class="card shadow p-5">
        <div class="mb-4">
            <i class="fa-solid fa-circle-check text-success" style="font-size: 5rem;"></i>
        </div>
        <h2 class="text-success mb-3">Giao dịch thành công!</h2>
        <p class="fs-5">Cảm ơn bạn đã mua sắm tại TechStore. Đơn hàng của bạn đã được thanh toán qua VNPay.</p>
        <p>Hệ thống đã cập nhật trạng thái đơn hàng và ghi nhận giao dịch.</p>
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fa-solid fa-house"></i> Về trang chủ
            </a>
        </div>
    </div>
</div>

<!-- Tích hợp SweetAlert2 để bật popup thông báo góc phải -->
@if (TempData["SuccessMessage"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            showSuccessMsg('@TempData["SuccessMessage"]');
        });
    </script>
}