<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Đổi title mặc định cho phù hợp với dự án -->
    <title>@ViewData["Title"] - TechStore</title>

    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ECommerceWeb.styles.css" asp-append-version="true" />

    <!-- Đã sửa lỗi dư dấu > ở thẻ FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
</head>
<body>
    <header>
        <!-- Chuyển Navbar sang giao diện nền tối (bg-dark) giống bản thiết kế -->
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-computer"></i> TechStore
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <!-- Menu chính bên trái -->
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                        </li>
                    </ul>

                    <!-- Thanh tìm kiếm ở giữa -->
                    <form class="d-flex mx-auto w-50" asp-controller="Product" asp-action="Search" method="get">
                        <input class="form-control me-2" type="search" name="keyword" placeholder="Tìm kiếm linh kiện..." aria-label="Search">
                        <button class="btn btn-primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </form>

                    <!-- Khu vực Auth và Giỏ hàng bên phải (ms-auto) -->
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- Dropdown User -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-user-check"></i> Chào, @User.Identity.Name!
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <!-- Chỉ hiển thị nút Admin nếu user có Role là Admin -->
                                    @if (User.HasClaim(System.Security.Claims.ClaimTypes.Role, "Admin"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Trang Quản trị</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- Nút Login / Register -->
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Auth" asp-action="Login"><i class="fa-solid fa-right-to-bracket"></i> Đăng nhập</a>
                            </li>
                        }

                        <!-- Nút Giỏ hàng nổi bật -->
                        <li class="nav-item ms-2">
                            <a class="btn btn-warning" asp-controller="Cart" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping"></i> Giỏ hàng
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Cập nhật Footer -->
    <footer class="border-top footer text-muted bg-dark text-light pt-3 pb-3 mt-5">
        <div class="container text-center text-light">
            &copy; 2026 - TechStore - Hệ thống bán lẻ linh kiện máy tính. <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-primary">Privacy</a>
        </div>
    </footer>

    <!-- Scripts dùng chung -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Thư viện Validation của ASP.NET Core -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- File JS custom của team -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>