@model ECommerceWeb.ViewModels.ProductCardViewModel

<div class="product-card h-100 d-flex flex-column">
    <div class="product-image">
        @if (Model.IsNew)
        {
            <span class="badge-new">NEW</span>
        }
        else if (Model.DiscountPercent.HasValue)
        {
            <span class="badge-discount">-@Model.DiscountPercent%</span>
        }
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)" alt="@Model.ProductName">
    </div>
    <div class="p-3 d-flex flex-column flex-grow-1">
        <div class="text-uppercase text-muted small fw-bold mb-1" style="font-size:.72rem;">@Model.CategoryName</div>
        <div class="product-title mb-2">@Model.ProductName</div>
        <div class="mb-2" style="color:#ffc107; font-size:.85rem;">
            ★★★★★ (@Model.Rating.ToString("0.0")) <span class="text-muted">(@Model.ReviewCount)</span>
        </div>
        <div class="mb-3">
            <span class="fw-bold" style="color:#d70018; font-size:18px;">@Model.Price.ToString("N0")đ</span>
            @if (Model.OldPrice.HasValue)
            {
                <span class="text-muted text-decoration-line-through small ms-2">@Model.OldPrice.Value.ToString("N0")đ</span>
            }
        </div>
        <div class="d-flex gap-2 mt-auto">
            <a href="@Model.DetailUrl" class="btn btn-outline-dark btn-sm flex-fill">Chi tiết</a>
            <a href="#" class="btn btn-warning btn-sm flex-fill"><i class="fa-solid fa-cart-shopping"></i> Thêm vào giỏ</a>
        </div>
    </div>
</div>
