<section class="container my-4">
    <div class="row g-3">
        <!-- Khối chính bên trái -->
        <div class="col-lg-8">
            <div class="position-relative h-100 overflow-hidden rounded-4 bg-dark"
                 style="min-height: 460px;">

                <!-- THAY LINK ẢNH BANNER CHÍNH TẠI src -->
                <img src="https://admin.hpctech.vn/admin/upload/home_banner/slider-banner/origin/saletoannganhhang-1784402006109.png"
                     alt="Build Your Dream PC"
                     class="position-absolute top-0 start-0 w-100 h-100"
                     style="object-fit: cover;" />

                <!-- Lớp phủ tối để chữ trắng luôn dễ đọc -->
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-75"></div>

                <div class="position-relative z-1 d-flex flex-column justify-content-center h-100 text-white p-4 p-lg-5"
                     style="min-height: 460px;">

                    <span class="badge bg-warning text-dark align-self-start mb-3">
                        HOT SALE
                    </span>

                    <h1 class="fw-bold display-5">
                        Build Your<br />
                        Dream PC
                    </h1>

                    <p class="text-white-50 mb-4"
                       style="max-width: 480px;">
                        Khám phá sức mạnh vô hạn với các linh kiện PC cao cấp nhất.
                        Nhận ngay ưu đãi độc quyền khi build PC tại @ViewBag.StoreName.
                    </p>

                    <div class="d-flex gap-2 flex-wrap">
                        <a href="#"
                           class="btn btn-warning">
                            Bắt đầu Build
                        </a>

                        <a href="#"
                           class="btn btn-outline-light">
                            PC Configurators
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hai khối phụ bên phải -->
        <div class="col-lg-4">
            <div class="row g-3 h-100">

                <!-- Banner phụ 1 -->
                <div class="col-12">
                    <a href="#"
                       class="position-relative d-block overflow-hidden rounded-4 text-decoration-none bg-dark"
                       style="min-height: 220px;">

                        <!-- THAY LINK ẢNH BANNER PHỤ 1 TẠI src -->
                        <img src="https://theme.hstatic.net/200000751217/1001100329/14/home-four-banner-image-item-4.png?v=375"
                             alt="@ViewBag.PromoTitle1"
                             class="position-absolute top-0 start-0 w-100 h-100"
                             style="object-fit: cover;" />

                        <!-- Lớp phủ tối -->
                        <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-75"></div>

                        <div class="position-relative z-1 d-flex flex-column justify-content-end text-white p-4"
                             style="min-height: 220px;">

                            <span class="badge bg-warning text-dark align-self-start mb-2">
                                HOT
                            </span>

                            <div class="fw-bold fs-5">
                                @ViewBag.PromoTitle1
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Banner phụ 2 -->
                <div class="col-12">
                    <a href="#"
                       class="position-relative d-block overflow-hidden rounded-4 text-decoration-none bg-dark"
                       style="min-height: 220px;">

                        <!-- THAY LINK ẢNH BANNER PHỤ 2 TẠI src -->
                        <img src="https://cdn.hstatic.net/themes/1000369156/1001400986/14/slider_1.jpg?v=187"
                             alt="@ViewBag.PromoTitle2"
                             class="position-absolute top-0 start-0 w-100 h-100"
                             style="object-fit: cover;" />

                        <!-- Lớp phủ tối -->
                        <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-75"></div>

                        <div class="position-relative z-1 d-flex flex-column justify-content-end text-white p-4"
                             style="min-height: 220px;">

                            <div class="fw-bold fs-5">
                                @ViewBag.PromoTitle2
                            </div>

                            <small class="text-white-50">
                                @ViewBag.PromoSubtitle2
                            </small>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
