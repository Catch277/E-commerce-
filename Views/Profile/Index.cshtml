@using ECommerceWeb.ViewModels
@model ECommerceWeb.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<style>
    body {
        background-color: #f7f9fd;
    }
    /* surface theo DESIGN.md */

    /* Các tag hạng thành viên */
    .badge-tier {
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: bold;
    }

    .badge-null {
        background-color: #8c8c8c;
        color: white;
    }

    .badge-student {
        background-color: #10b981;
        color: white;
    }

    .empty-state-img {
        max-width: 120px;
        margin-bottom: 15px;
        opacity: 0.8;
    }
     .sidebar-menu .list-group-item:hover {
        background-color: #fff3c2; /* Vàng nhạt */
        color: #785900; /* Vàng đậm */
    }
</style>

<div class="container mt-4 mb-5">

    <!-- SECTION 1: Header - Tổng quan tài khoản -->
    <div class="profile-card p-3 mb-3">
        <div class="row align-items-center text-center text-md-start">

            <!-- Cột 1: Thông tin User -->
            <div class="col-md-5 d-flex align-items-center border-end mb-3 mb-md-0">
                <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=ffc107&color=6d5100&rounded=true&size=64" alt="Avatar" class="me-3">
                <div>
                    <h5 class="mb-1 fw-bold">@Model.FullName</h5>
                    <div class="text-muted small mb-2">@Model.Phone <i class="fa-solid fa-pen ms-1 cursor-pointer"></i></div>
                    <div>
                        <span class="badge-tier badge-null me-1">@Model.MemberTier</span>
                    </div>
                </div>
            </div>

            <!-- Cột 2: Tổng đơn hàng -->
            <div class="col-md-3 border-end mb-3 mb-md-0">
                <div class="d-flex align-items-center justify-content-center justify-content-md-start px-md-3">
                    <i class="fa-solid fa-cart-shopping fs-3 me-3" style="color:#ffc107;"></i>
                    <div>
                        <h4 class="mb-0 fw-bold">@Model.TotalOrders</h4>
                        <span class="text-muted small">Tổng số đơn hàng đã mua</span>
                    </div>
                </div>
            </div>

            <!-- Cột 3: Tổng tiền tích lũy -->
            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center justify-content-md-start px-md-3">
                    <i class="fa-solid fa-sack-dollar fs-3 me-3" style="color:#ffc107;"></i>
                    <div>
                        <h4 class="mb-0 fw-bold">@Model.TotalSpent.ToString("N0")đ</h4>
                        <span class="text-muted small">Tổng tiền tích lũy</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SECTION 2: Thanh Quick Links (dùng chung) -->
    @await Html.PartialAsync("_ProfileQuickLinksPartial")

    <!-- SECTION 3: Main Layout (Sidebar + Nội dung) -->
    <div class="row">
        <!-- Sidebar Menu (dùng chung) -->
        <div class="col-lg-3 mb-4">
            @await Html.PartialAsync("_ProfileSidebarPartial")
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">

            <!-- Banners Thông báo -->
            <div class="alert d-flex justify-content-between align-items-center profile-card mb-3" role="alert" style="background-color:#fff3c2; color:#6d5100;">
                <span><i class="fa-solid fa-circle-info me-2"></i> Đăng ký Thẻ thành viên để nhận mã giảm giá đến 10%.</span>
                <a href="#" class="text-decoration-none fw-bold" style="color:#6d5100;">Đăng ký ngay</a>
            </div>

            <!-- Grid: Đơn hàng & Ưu đãi -->
            <div class="row mb-3">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="profile-card p-4 h-100">
                        <h6 class="fw-bold mb-4">Đơn hàng gần đây</h6>
                        <div class="text-center py-4">
                            <i class="fa-solid fa-box-open text-muted" style="font-size: 4rem; opacity: 0.3; margin-bottom: 15px;"></i>
                            <p class="text-muted small mb-1">Bạn chưa có đơn hàng nào gần đây?</p>
                            <a asp-controller="Home" asp-action="Index" class="text-decoration-none fw-semibold" style="color:#785900;">Mua sắm ngay</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="profile-card p-4 h-100">
                        <h6 class="fw-bold mb-4">Ưu đãi của bạn</h6>
                        <div class="text-center py-4">
                            <i class="fa-solid fa-tags text-muted" style="font-size: 4rem; opacity: 0.3; margin-bottom: 15px;"></i>
                            <p class="text-muted small mb-1">Bạn chưa có ưu đãi nào.</p>
                            <a asp-controller="Product" asp-action="Index" class="text-decoration-none fw-semibold" style="color:#785900;">Xem sản phẩm</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Block: Sản phẩm yêu thích -->
            <div class="profile-card p-4">
                <h6 class="fw-bold mb-4">Sản phẩm yêu thích</h6>

                <div id="favorite-products-list" class="@(Model.FavoriteProducts.Any() ? "" : "d-none")">
                @if (Model.FavoriteProducts.Any())
                {
                    <div class="row g-3">
                        @foreach (var product in Model.FavoriteProducts)
                        {
                            <div class="col-6 col-md-4 col-lg-3 favorite-product-item" data-product-id="@product.ProductID">
                                <partial name="_ProductCard" model="product" />
                            </div>
                        }
                    </div>
                }
                </div>

                <div id="favorite-products-empty" class="text-center py-5 @(Model.FavoriteProducts.Any() ? "d-none" : "")">
                    <i class="fa-regular fa-heart text-muted" style="font-size: 4rem; opacity: 0.3; margin-bottom: 15px;"></i>
                    <p class="text-muted small mb-1">Bạn chưa có sản phẩm nào yêu thích? Hãy bắt đầu mua sắm ngay nào!</p>
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none fw-semibold" style="color:#785900;">Mua sắm ngay</a>
                </div>
            </div>

        </div>
    </div>
</div>
