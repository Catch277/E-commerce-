@model ECommerceWeb.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<style>
    body {
        background-color: #f7f9fd;
    }

    .confetti-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1000;
    }

    .success-card {
        border-radius: 18px;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
        background: #fff;
    }

    .success-icon-wrap {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: rgba(16, 185, 129, .1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
    }

        .success-icon-wrap i {
            font-size: 3.2rem;
            color: #10b981;
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #eceef2;
    }

        .info-row:last-child {
            border-bottom: none;
            padding-top: 14px;
        }

    .info-label {
        color: #575e70;
    }

    .info-block .label-small {
        font-size: .78rem;
        color: #575e70;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 4px;
    }

    .product-item-box {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px;
        border-radius: 12px;
        background: #f2f4f8;
        border: 1px solid #e6e8ec;
        margin-bottom: 10px;
    }

        .product-item-box img {
            width: 72px;
            height: 72px;
            object-fit: contain;
            background: #fff;
            border-radius: 8px;
            padding: 4px;
            flex-shrink: 0;
        }

        .product-item-box .product-name {
            font-weight: 600;
            font-size: .95rem;
        }

        .product-item-box .product-meta {
            color: #575e70;
            font-size: .85rem;
        }

    .btn-success-primary {
        background: #ffc107;
        color: #212529;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        padding: 14px 20px;
        transition: all .2s ease;
    }

        .btn-success-primary:hover {
            background: #e0a800;
            color: #212529;
            transform: translateY(-2px);
        }

    .btn-success-outline {
        border: 2px solid #ffc107;
        color: #785900;
        font-weight: 700;
        border-radius: 10px;
        padding: 14px 20px;
        background: transparent;
        transition: all .2s ease;
    }

        .btn-success-outline:hover {
            background: rgba(255,193,7,.1);
            color: #785900;
        }
</style>

<canvas class="confetti-canvas" id="confetti"></canvas>

<main class="py-5">
    <div class="container" style="max-width: 800px;">

        <!-- Trạng thái thành công -->
        <div class="text-center mb-4" id="successHeader" style="opacity:0; transform: translateY(20px); transition: all .8s ease-out;">
            <div class="success-icon-wrap">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <h1 class="fw-bold mb-2" style="font-size:24px;">Đặt hàng thành công!</h1>
            <p class="text-secondary mx-auto" style="max-width:520px;">
                Cảm ơn bạn đã tin tưởng mua sắm tại PC Store. Đơn hàng của bạn đang được xử lý.
                Một email xác nhận đã được gửi đến hộp thư của bạn.
            </p>
        </div>

        <!-- Card thông tin đơn hàng -->
        <div class="success-card p-4 p-md-5 mb-4">
            <div class="row g-4">
                <!-- Thông tin đơn hàng -->
                <div class="col-md-6">
                    <h2 class="fw-semibold mb-3 d-flex align-items-center gap-2" style="font-size:17px;">
                        <i class="fa-solid fa-receipt" style="color:#785900;"></i> Thông tin đơn hàng
                    </h2>
                    <div class="info-block">
                        <div class="info-row">
                            <span class="info-label">Mã đơn hàng:</span>
                            <span class="fw-bold">#@Model.OrderID</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Ngày đặt:</span>
                            <span class="fw-medium">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Phương thức thanh toán:</span>
                            <span class="fw-medium" style="color:#575e70;">@Model.PaymentMethod</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Trạng thái:</span>
                            <span class="badge" style="background:#fff3c2; color:#6d5100;">@Model.OrderStatus</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label fw-bold" style="color:#212529;">Tổng thanh toán:</span>
                            <span class="fw-bold" style="font-size:18px; color:#b8860b;">@Model.TotalAmount.ToString("N0")đ</span>
                        </div>
                    </div>
                </div>

                <!-- Thông tin giao hàng -->
                <div class="col-md-6">
                    <h2 class="fw-semibold mb-3 d-flex align-items-center gap-2" style="font-size:17px;">
                        <i class="fa-solid fa-truck" style="color:#785900;"></i> Thông tin giao hàng
                    </h2>
                    <div class="d-flex flex-column gap-3">
                        <div>
                            <div class="label-small">Người nhận</div>
                            <div class="fw-bold">@Model.CustomerName</div>
                        </div>
                        <div>
                            <div class="label-small">Số điện thoại</div>
                            <div class="fw-medium">@Model.CustomerPhone</div>
                        </div>
                        <div>
                            <div class="label-small">Địa chỉ</div>
                            <div class="fw-medium" style="line-height:1.6;">@Model.ShippingAddress</div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.Note))
                        {
                            <div>
                                <div class="label-small">Ghi chú</div>
                                <div class="fw-medium">@Model.Note</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <hr class="my-4" style="border-color:#eceef2;">

            <!-- Sản phẩm đã mua -->
            <div class="mb-4">
                <h2 class="fw-semibold mb-3" style="font-size:17px;">Sản phẩm đã mua</h2>
                @foreach (var detail in Model.OrderDetails)
                {
                    <div class="product-item-box">
                        <img src="@(string.IsNullOrEmpty(detail.Product.ImageUrl) ? "/images/no-image.png" : detail.Product.ImageUrl)" alt="@detail.Product.ProductName">
                        <div class="flex-grow-1">
                            <div class="product-name">@detail.Product.ProductName</div>
                            <div class="product-meta">
                                Số lượng: @detail.Quantity.ToString("00")
                                <span class="mx-1">•</span>
                                <span class="fw-bold" style="color:#785900;">@detail.UnitPrice.ToString("N0")đ</span>
                            </div>
                        </div>
                        <div class="fw-bold" style="color:#b8860b;">
                            @((detail.Quantity * detail.UnitPrice).ToString("N0"))đ
                        </div>
                    </div>
                }

                @if (Model.DiscountAmount > 0 || Model.ShippingFee >= 0)
                {
                    <div class="d-flex flex-column gap-1 small mt-3 pt-3" style="border-top:1px solid #eceef2;">
                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between text-success">
                                <span>Giảm giá</span>
                                <span>-@Model.DiscountAmount.ToString("N0")đ</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between">
                            <span class="text-secondary">Phí vận chuyển</span>
                            <span>@(Model.ShippingFee > 0 ? Model.ShippingFee.ToString("N0") + "đ" : "Miễn phí")</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Nút hành động -->
            <div class="d-flex flex-column flex-md-row gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn-success-primary flex-fill d-flex align-items-center justify-content-center gap-2 text-decoration-none">
                    Tiếp tục mua sắm <i class="fa-solid fa-arrow-right"></i>
                </a>
                <a asp-controller="Profile" asp-action="OrderHistory" class="btn-success-outline flex-fill d-flex align-items-center justify-content-center gap-2 text-decoration-none">
                    <i class="fa-solid fa-clock-rotate-left"></i> Xem lịch sử đơn hàng
                </a>
            </div>
        </div>

        <!-- Ghi chú hỗ trợ -->
        <div class="text-center">
            <p class="text-secondary small mb-0">
                Cần hỗ trợ? Gọi ngay <span class="fw-bold" style="color:#785900;">1900 6789</span> (8:00 - 21:00 hàng ngày)
            </p>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        // Fade-in cho phần header
        window.addEventListener('DOMContentLoaded', function () {
            var header = document.getElementById('successHeader');
            requestAnimationFrame(function () {
                header.style.opacity = '1';
                header.style.transform = 'translateY(0)';
            });
        });
    </script>
}
