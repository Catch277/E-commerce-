@model IEnumerable<ECommerceWeb.Models.Voucher>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý khuyến mãi";

    string selectedStatus =
        ViewBag.SelectedStatus as string ?? "";
}

<div class="d-flex flex-wrap justify-content-between
    align-items-center gap-3 mb-4">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-megaphone text-warning me-2"></i>
            Quản lý khuyến mãi
        </h2>

        <p class="text-muted mb-0">
            Tạo, chỉnh sửa và kiểm soát các mã giảm giá.
        </p>
    </div>

    <a asp-action="CreateVoucher"
       class="btn btn-warning fw-bold">
        <i class="bi bi-plus-circle me-1"></i>
        Tạo khuyến mãi
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle-fill me-2"></i>
        @TempData["ErrorMessage"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Vouchers"
              method="get"
              class="row g-3">

            <div class="col-md-8">
                <label class="form-label fw-semibold">
                    Tìm kiếm
                </label>

                <input type="search"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Tìm theo mã hoặc tên chương trình..." />
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">
                    Trạng thái
                </label>

                <select name="status"
                        class="form-select">
                    <option value="">
                        Tất cả
                    </option>

                    <option value="active"
                            selected="@(selectedStatus == "active")">
                        Đang hoạt động
                    </option>

                    <option value="inactive"
                            selected="@(selectedStatus == "inactive")">
                        Đã tắt
                    </option>

                    <option value="expired"
                            selected="@(selectedStatus == "expired")">
                        Đã hết hạn
                    </option>

                    <option value="out-of-uses"
                            selected="@(selectedStatus == "out-of-uses")">
                        Hết lượt sử dụng
                    </option>
                </select>
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <button type="submit"
                        class="btn btn-dark w-100">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Mã khuyến mãi</th>
                    <th>Ưu đãi</th>
                    <th>Điều kiện</th>
                    <th>Lượt sử dụng</th>
                    <th>Hết hạn</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7"
                            class="text-center text-muted py-5">
                            Chưa có mã khuyến mãi phù hợp.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var voucher in Model)
                    {
                        bool expired =
                            voucher.ExpiryDate < DateTime.Now;

                        bool outOfUses =
                            voucher.UsageLimit.HasValue &&
                            voucher.UsedCount >=
                            voucher.UsageLimit.Value;

                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold font-monospace">
                                    @voucher.Code
                                </div>

                                <small class="text-muted">
                                    @voucher.Title
                                </small>
                            </td>

                            <td>
                                @if (voucher.DiscountType == "Percent")
                                {
                                    <strong class="text-success">
                                        Giảm @voucher.DiscountValue.ToString("0.##")%
                                    </strong>

                                    @if (voucher.MaxDiscountAmount.HasValue)
                                    {
                                        <div class="small text-muted">
                                            Tối đa
                                            @voucher.MaxDiscountAmount.Value.ToString("N0") đ
                                        </div>
                                    }
                                }
                                else
                                {
                                    <strong class="text-success">
                                        Giảm @voucher.DiscountValue.ToString("N0") đ
                                    </strong>
                                }
                            </td>

                            <td>
                                Đơn từ
                                <strong>
                                    @voucher.MinOrderValue.ToString("N0") đ
                                </strong>
                            </td>

                            <td>
                                <strong>@voucher.UsedCount</strong>
                                /
                                @(voucher.UsageLimit?.ToString()
                                    ?? "Không giới hạn")
                            </td>

                            <td>
                                @voucher.ExpiryDate.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @if (!voucher.IsActive)
                                {
                                    <span class="badge bg-secondary">
                                        Đã tắt
                                    </span>
                                }
                                else if (expired)
                                {
                                    <span class="badge bg-danger">
                                        Hết hạn
                                    </span>
                                }
                                else if (outOfUses)
                                {
                                    <span class="badge bg-danger">
                                        Hết lượt
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Hoạt động
                                    </span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                <a asp-action="EditVoucher"
                                   asp-route-id="@voucher.VoucherID"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <form asp-action="ToggleVoucherStatus"
                                      asp-route-id="@voucher.VoucherID"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-sm
                                        @(voucher.IsActive
                                                ? "btn-outline-warning"
                                                : "btn-outline-success")"
                                            title="@(voucher.IsActive
                                                                                            ? "Tắt voucher"
                                                                                            : "Bật voucher")">

                                        <i class="bi
                                            @(voucher.IsActive
                                               ? "bi-pause-circle"
                                               : "bi-play-circle")">
                                        </i>
                                    </button>
                                </form>

                                <form asp-action="DeleteVoucher"
                                      asp-route-id="@voucher.VoucherID"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm(
                                    'Bạn chắc chắn muốn xóa voucher này?');">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>