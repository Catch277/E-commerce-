@model ECommerceWeb.ViewModels.Admin.AdminVoucherViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Sửa khuyến mãi";
}

<div class="card border-0 shadow-sm mx-auto"
     style="max-width: 950px;">
    <div class="card-body p-4 p-lg-5">
        <div class="mb-4">
            <a asp-action="Vouchers"
               class="text-decoration-none text-muted">
                <i class="bi bi-arrow-left"></i>
                Quay lại danh sách
            </a>

            <h2 class="fw-bold mt-3 mb-1">
                Sửa mã @Model.Code
            </h2>

            <p class="text-muted mb-0">
                Cập nhật điều kiện và trạng thái chương trình.
            </p>
        </div>

        <form asp-action="EditVoucher"
              asp-route-id="@Model.VoucherID"
              method="post">

            @Html.AntiForgeryToken()

            <input asp-for="VoucherID"
                   type="hidden" />

            <partial name="_VoucherForm"
                     model="Model" />

            <div class="d-flex gap-2 mt-4">
                <button type="submit"
                        class="btn btn-primary fw-bold">
                    <i class="bi bi-check-lg me-1"></i>
                    Lưu thay đổi
                </button>

                <a asp-action="Vouchers"
                   class="btn btn-light">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}