@model ECommerceWeb.ViewModels.Admin.AdminVoucherViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Tạo khuyến mãi";
}

<div class="card border-0 shadow-sm mx-auto"
     style="max-width: 950px;">

    <div class="card-body p-4 p-lg-5">

        <div class="mb-4">
            <a asp-controller="Admin"
               asp-action="Vouchers"
               class="text-decoration-none text-muted">

                <i class="bi bi-arrow-left"></i>
                Quay lại danh sách
            </a>

            <h2 class="fw-bold mt-3 mb-1">
                Tạo chương trình khuyến mãi
            </h2>

            <p class="text-muted mb-0">
                Mã khuyến mãi mới sẽ được sử dụng tại trang thanh toán.
            </p>
        </div>

        <form asp-controller="Admin"
              asp-action="CreateVoucher"
              method="post">

            @Html.AntiForgeryToken()

            <partial name="_VoucherForm"
                     model="Model" />

            <div class="d-flex gap-2 mt-4">
                <button type="submit"
                        class="btn btn-warning fw-bold px-4">

                    <i class="bi bi-plus-circle me-1"></i>
                    Tạo khuyến mãi
                </button>

                <a asp-controller="Admin"
                   asp-action="Vouchers"
                   class="btn btn-light px-4">

                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}