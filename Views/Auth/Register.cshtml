@model ECommerceWeb.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

@section Styles {
    <link rel="stylesheet" href="~/css/register.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-left">
            <h2>Đăng ký ngay<br>để mua sắm</h2>
            <p>Đăng ký tài khoản để trải nghiệm dịch vụ mua sắm tuyệt vời.</p>
        </div>
        <div class="auth-right">
            <h3>Đăng ký</h3>
            <p class="text-muted-desc">Vui lòng điền thông tin để tạo tài khoản mới.</p>

            <form asp-controller="Auth" asp-action="Register" method="post">
                <div class="row mb-3">
                    <!-- Tên -->
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">Họ và tên</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên..."/>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <!-- Email -->
                    <div class="col-md-6 mt-3 mt-md-0">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="Nhập email..."/>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>
                <!-- Địa chỉ -->
                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Địa chỉ</label>
                    <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ..."/>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
                <!-- SĐT -->
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại..."/>
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <!-- Giới tính -->
                <div class="mb-3">
                    <label class="form-label">Giới tính</label>
                    <div class="d-flex gap-4">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="Gender" value="Nam" id="genderMale">
                            <label class="form-check-label" for="genderMale">Nam</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="Gender" value="Nữ" id="genderFemale">
                            <label class="form-check-label" for="genderFemale">Nữ</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="Gender" value="" id="genderNone" checked>
                            <label class="form-check-label" for="genderNone">Để trống</label>
                        </div>
                    </div>
                    <span asp-validation-for="Gender" class="text-danger small"></span>
                </div>
                <!-- Mật khẩu -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <div class="position-relative">
                        <input asp-for="Password" class="form-control pe-5" placeholder="Nhập mật khẩu..." id="Password" autocomplete="new-password"/>
                        <button class="btn border-0 bg-transparent position-absolute top-50 end-0 translate-middle-y toggle-password" type="button" data-target="Password">
                            <i class="bi bi-eye fs-5 text-muted pwd-icon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>

                    <!-- Thanh Progress Bar -->
                    <div class="progress mt-2 mb-2" style="height: 6px;">
                        <div id="password-progress" class="progress-bar" role="progressbar" style="width: 0%; transition: width 0.4s ease, background-color 0.4s ease;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>

                    <div class="password-rules-container mt-2">
                        <ul class="list-unstyled mb-0" id="password-rules">
                            <li id="rule-length" class="text-muted"><i class="bi bi-check-circle"></i> Tối thiểu 6 ký tự</li>
                            <li id="rule-upper" class="text-muted"><i class="bi bi-check-circle"></i> Ít nhất 1 chữ hoa</li>
                            <li id="rule-number" class="text-muted"><i class="bi bi-check-circle"></i> Ít nhất 1 chữ số</li>
                            <li id="rule-special" class="text-muted"><i class="bi bi-check-circle"></i> Ít nhất 1 ký tự đặc biệt</li>
                        </ul>
                    </div>
                </div>
                <!-- Xác nhận mật khẩu -->
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                    <div class="position-relative">
                        <input asp-for="ConfirmPassword" class="form-control pe-5" placeholder="Nhập lại mật khẩu..." id="ConfirmPassword" autocomplete="new-password"/>
                        <button class="btn border-0 bg-transparent position-absolute top-50 end-0 translate-middle-y toggle-password" type="button" data-target="ConfirmPassword">
                            <i class="bi bi-eye fs-5 text-muted pwd-icon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-auth-submit mt-2 mb-4">
                    Đăng ký
                </button>

                <div class="text-center">
                    <span class="text-muted">Đã có tài khoản? </span>
                    <a asp-controller="Auth" asp-action="Login" class="auth-link">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script src="~/js/register.js"></script>
}