@model ECommerceWeb.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

@section Styles {
    <link rel="stylesheet" href="~/css/register.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-left">
            <!-- 1. Fix rớt dòng: Thêm style trắng ép buộc không rớt dòng -->
            <h2 class="text-nowrap" style="white-space: nowrap;">Chào mừng trở lại</h2>
            <p>Đăng nhập để tiếp tục mua sắm và tận hưởng những ưu đãi hấp dẫn từ PC Store.</p>
        </div>
        <div class="auth-right">
            <h3>Đăng nhập</h3>
            <p class="text-muted-desc">Vui lòng điền thông tin để đăng nhập vào tài khoản của bạn.</p>

            <form asp-controller="Auth" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="Nhập email..." autocomplete="username" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <div class="position-relative">
                        <input asp-for="Password" class="form-control pe-5" placeholder="Nhập mật khẩu..." id="Password" autocomplete="current-password" />
                        <button class="btn border-0 bg-transparent position-absolute top-50 end-0 translate-middle-y toggle-password" type="button" data-target="Password">
                            <i class="bi bi-eye fs-5 text-muted pwd-icon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <!-- 2. Fix Remember Me: Ép kích thước cố định cho checkbox và dùng Flexbox để căn chỉnh -->
                <div class="mb-4 form-check d-flex align-items-center">
                    <input asp-for="RememberMe" class="form-check-input me-2" style="width: 1.25em; height: 1.25em; flex-shrink: 0; margin-top: 0; appearance: auto;"/>
                    <label asp-for="RememberMe" class="form-check-label text-muted mb-0">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn-auth-submit mt-2 mb-4">
                    Đăng nhập
                </button>

                <div class="text-center">
                    <span class="text-muted">Chưa có tài khoản? </span>
                    <a asp-controller="Auth" asp-action="Register" class="auth-link">Đăng ký ngay</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script src="~/js/register.js"></script>
}