                    <img src="https://upload.wikimedia.org/wikipedia/commons/2/21/Nvidia_logo.svg" alt="NVIDIA">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2e/ASUS_Logo.svg/500px-ASUS_Logo.svg.png" alt="ASUS">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Micro-Star_International_logo.svg/500px-Micro-Star_International_logo.svg.png" alt="MSI">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/1/17/Logitech_logo.svg" alt="Logitech">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c9/Lenovo_%282015%29.svg/500px-Lenovo_%282015%29.svg.png" alt="Lenovo">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/f/fa/Apple_logo_black.svg/330px-Apple_logo_black.svg.png" alt="Apple">
                </div>
                <!-- Bản sao y hệt để tạo vòng lặp vô tận -->
                <div class="brand-content" aria-hidden="true">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/85/Intel_logo_2023.svg/500px-Intel_logo_2023.svg.png" alt="Intel">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/2/21/Nvidia_logo.svg" alt="NVIDIA">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2e/ASUS_Logo.svg/500px-ASUS_Logo.svg.png" alt="ASUS">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Micro-Star_International_logo.svg/500px-Micro-Star_International_logo.svg.png" alt="MSI">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/1/17/Logitech_logo.svg" alt="Logitech">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c9/Lenovo_%282015%29.svg/500px-Lenovo_%282015%29.svg.png" alt="Lenovo">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/f/fa/Apple_logo_black.svg/330px-Apple_logo_black.svg.png" alt="Apple">
                </div>
            </div>
        </div>

        <!-- ROW 2: Trượt sang PHẢI -->
        <div class="marquee-row">
            <div class="brand-track track-right">
                <div class="brand-content">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/18/Dell_logo_2016.svg/330px-Dell_logo_2016.svg.png" alt="Dell">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/00/Acer_2011.svg/500px-Acer_2011.svg.png" alt="Acer">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b7/Samsung_Black_icon.svg/960px-Samsung_Black_icon.svg.png" alt="Samsung">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/LG_logo_%282014%29.svg/500px-LG_logo_%282014%29.svg.png" alt="LG">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/05/HP_logo_2025.svg/330px-HP_logo_2025.svg.png" alt="HP">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c3/Gigabyte_Technology_logo_20080107.svg/500px-Gigabyte_Technology_logo_20080107.svg.png" alt="Gigabyte">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/Sony_logo.svg/960px-Sony_logo.svg.png" alt="Sony">
                </div>
                <!-- Bản sao y hệt để tạo vòng lặp vô tận -->
