                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/18/Dell_logo_2016.svg/330px-Dell_logo_2016.svg.png" alt="Dell">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/00/Acer_2011.svg/500px-Acer_2011.svg.png" alt="Acer">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b7/Samsung_Black_icon.svg/960px-Samsung_Black_icon.svg.png" alt="Samsung">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/LG_logo_%282014%29.svg/500px-LG_logo_%282014%29.svg.png" alt="LG">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/05/HP_logo_2025.svg/330px-HP_logo_2025.svg.png" alt="HP">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c3/Gigabyte_Technology_logo_20080107.svg/500px-Gigabyte_Technology_logo_20080107.svg.png" alt="Gigabyte">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/Sony_logo.svg/960px-Sony_logo.svg.png" alt="Sony">
                </div>
